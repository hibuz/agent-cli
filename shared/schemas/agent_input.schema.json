{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Input",
  "type": "object",
  "required": ["user_id", "request"],
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Unique identifier for the user"
    },
    "session_id": {
      "type": "string",
      "description": "Identifier for the current conversation/session"
    },
    "request": {
      "type": "string",
      "description": "User's natural language request"
    },
    "context": {
      "type": "object",
      "description": "Optional contextual signals (weather, time, location, etc.)",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}